[sub_resource type="GDScript" id="GDScript_jfcuo"]
script/source = "extends Control

@export var _path_system : Node

var _is_can_drop : bool = false

func _ready() -> void:
	_is_can_drop = false
	get_window().files_dropped.connect(_on_files_dropped)

func can_drop(value : bool):
	_is_can_drop = value

func _on_files_dropped(files: PackedStringArray) -> void:
	if _is_can_drop == false: return
	if get_rect().has_point(get_local_mouse_position()):
		_handle_drop_logic(files)

func _handle_drop_logic(files: PackedStringArray) -> void:
	if files.is_empty(): return
	
	var raw_path = files[0]
	var clean_path = raw_path.replace(\"\\\\\", \"/\").simplify_path()
	
	if DirAccess.dir_exists_absolute(clean_path):
		if _path_system and _path_system.has_method(\"_process_scan\"):
			_path_system._process_scan(clean_path)
			print(\"Передано на сканирование: \", clean_path)
"

