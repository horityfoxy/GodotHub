[sub_resource type="GDScript" id="GDScript_t4bcl"]
script/source = "extends Panel

@export var _view_window : Panel
@export_category(\"buttons\")
@export var _godot_hub_button : Button
@export var _lineseedjp_button : Button
@export var _godot_engine_button : Button
@export var _about_program_button : Button
@export var _close_about_window_button : Button

func _ready() -> void:
	hide()
	_close_about_window_button.pressed.connect(_on_close_about_window_button_pressed)
	var buttons = [
		_godot_hub_button, 
		_lineseedjp_button, 
		_godot_engine_button, 
		_about_program_button
	]
	
	for btn in buttons: _connect_license_button(btn)

func _connect_license_button(btn: Button) -> void:
	if btn:
		btn.pressed.connect(func():
			var id_from_button = btn.get(\"ID\")
			if id_from_button != null:
				_view_window.text_update(id_from_button)
		)

func _on_close_about_window_button_pressed() -> void:
	disable()

func enable() -> void:
	show()

func disable() -> void:
	hide()
"

