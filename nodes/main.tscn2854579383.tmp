[sub_resource type="GDScript" id="GDScript_gtvj2"]
script/source = "extends Panel

@export var web_request : Control
@export var parcing_window : VBoxContainer
@export var allow_internet_button : Button

func _ready() -> void:
	allow_internet_button.pressed.connect(allow_internet)

func enable() -> void:
	if VersionControl.is_internet_allowed(): parcing_window.enable()
	else: web_request.enable()

func allow_internet():
	VersionControl.set_internet_allowed(true)
	web_request.disable()
	parcing_window.enable()
"

[sub_resource type="GDScript" id="GDScript_m1xwi"]
script/source = "extends Control

func enable() -> void:
	show()

func disable() -> void:
	hide()
"

[sub_resource type="GDScript" id="GDScript_imhw3"]
script/source = "extends VBoxContainer

signal _network_connection_error

@export var _parcing_window : EngineVersionParser
@export var _parcing_hint : Label

func _ready() -> void:
	_parcing_window.network_connection_error.connect(_network_connection_error.emit)
	_parcing_hint.hide()

func disable():
	hide()

func enable() -> void:
	show()
	_parcing_hint.show()
	_parcing_window.new_version_found.connect(_hide_hint)
	_parcing_window.fetch_godot_releases()

func _hide_hint():
	_parcing_window.show()
	_parcing_hint.hide()
"

[sub_resource type="GDScript" id="GDScript_ibm61"]
script/source = "extends Control

@export var _start_parsing : Button
@export var _parcing_window : EngineVersionParser
@export var _parcing_hint : Label

func _ready() -> void:
	_parcing_window.network_connection_error.connect(enable)
	_start_parsing.pressed.connect(refresh_parsing)

func enable():
	show()

func disable():
	hide()

func refresh_parsing():
	_parcing_window.enable()
	_parcing_hint.hide()
	disable()
"

