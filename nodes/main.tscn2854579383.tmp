script/source = "extends Control

signal close_window

@export_category(\"Buttons\")
@export var _close_window_button : Button

@export_category(\"Windows\")
@export var _drag_and_drop_window : Panel

func _ready() -> void:
	hide()
	_close_window_button.pressed.connect(disable)

func enable() -> void:
	_drag_and_drop_window.can_drop(true)
	show()

func disable() -> void:
	_drag_and_drop_window.can_drop(false)
	close_window.emit()
	hide()
"

[sub_resource type="GDScript" id="GDScript_vr02l"]
script/source = "extends Node

@export_category(\"Buttons\")
@export var _scan_projects_button : Button
@export var _close_window_button : Button

@export_category(\"Dialogs\")
@export var _file_dialog : FileDialog

func _ready() -> void:
	_file_dialog.file_mode = FileDialog.FILE_MODE_OPEN_DIR
	_file_dialog.access = FileDialog.ACCESS_FILESYSTEM
	
	_scan_projects_button.pressed.connect(_on_scan_projects_pressed)
	_file_dialog.dir_selected.connect(_on_dir_selected)

func _on_scan_projects_pressed() -> void:
	_file_dialog.popup_centered_ratio(0.5)

func _on_dir_selected(path: String) -> void:
	_process_scan(path)

func _process_scan(path: String) -> void:
	_close_window_button.pressed.emit()
	_scan_recursive(path)
	print(\"Scan is completed\")

func _scan_recursive(path: String) -> void:
	var dir = DirAccess.open(path)
	if not dir: return
	
	if dir.file_exists(\"project.godot\"):
		var full_config_path = path.path_join(\"project.godot\")
		_register_project(full_config_path)
		return
	
	dir.list_dir_begin()
	var file_name = dir.get_next()
	
	while file_name != \"\":
		if dir.current_is_dir():
			if not file_name.begins_with(\".\"): 
				_scan_recursive(path.path_join(file_name))
		file_name = dir.get_next()
	dir.list_dir_end()

func _register_project(full_path: String) -> void:
	EventBus.project_found.emit(full_path)
	print(\"Project was found in path: \", full_path)
"

[sub_resource type="GDScript" id="GDScript_g653p"]
