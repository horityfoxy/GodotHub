[sub_resource type="GDScript" id="GDScript_usfbk"]
script/source = "extends HBoxContainer

@export_category(\"Buttons\")
@export var _settings_button : Button
@export var _edit_button : Button
@export var _projects_button : Button
@export var _varsions_button : Button

func _ready() -> void:
	_settings_button.pressed.connect(EventBus.settings_window_enable.emit)
	_edit_button.pressed.connect(_edit_mode)
	_projects_button.pressed.connect(_projects_enable)
	_varsions_button.pressed.connect(_versions_enable)

func _edit_mode():
	EventBus.activate_window_or_switch.emit()
	EventBus.edit_button_pressed.emit()

func _projects_enable():
	EventBus.activate_window_or_switch.emit()
	EventBus.switch_window_body.emit(\"projects\")
	_projects_button.button_pressed = true
	_varsions_button.button_pressed = false

func _versions_enable():
	EventBus.activate_window_or_switch.emit()
	EventBus.switch_window_body.emit(\"versions\")
	_varsions_button.button_pressed = true
	_projects_button.button_pressed = false
"

[sub_resource type="GDScript" id="GDScript_u2n8d"]
script/source = "extends Control

@export var _projects_window : Control
@export var _versions_window : Control

enum WindowState { PROJECTS, VERSIONS }
var _current_state : WindowState = WindowState.PROJECTS

var _tween : Tween

func _ready() -> void:
	var screen_width = get_viewport_rect().size.x
	EventBus.switch_window_body.connect(switch_window_body)
	_projects_window.position.x = 0
	_versions_window.position.x = screen_width
	_projects_window.show()
	_versions_window.hide()

func switch_window_body(state_name : String) -> void:
	var new_state : WindowState
	match state_name:
		\"projects\": new_state = WindowState.PROJECTS
		\"versions\": new_state = WindowState.VERSIONS
		_: 
			printerr(\"Incorrect header button value: \", state_name)
			return
	
	if new_state == _current_state: return
	_animate_swipe(new_state)
	_current_state = new_state

func _animate_swipe(target_state: WindowState) -> void:
	if _tween and _tween.is_running(): _tween.kill()
	
	_tween = create_tween().set_parallel(true)
	_tween.set_trans(Tween.TRANS_CUBIC).set_ease(Tween.EASE_OUT)
	
	var screen_width = get_viewport_rect().size.x
	var duration = 0.55
	
	match target_state:
		WindowState.VERSIONS:
			_versions_window.show()
			_tween.tween_property(_projects_window, \"position:x\", -screen_width, duration)
			_tween.tween_property(_versions_window, \"position:x\", 0, duration)
		WindowState.PROJECTS:
			_projects_window.show()
			_tween.tween_property(_versions_window, \"position:x\", screen_width, duration)
			_tween.tween_property(_projects_window, \"position:x\", 0, duration)
	
	_tween.finished.connect(func():
		_projects_window.visible = (target_state == WindowState.PROJECTS)
		_versions_window.visible = (target_state == WindowState.VERSIONS)
	) 
"

[sub_resource type="GDScript" id="GDScript_1n1q0"]
script/source = "extends Control

@export_category(\"Buttons\")
@export var add_project_button : Button

@export var _hint : Label
@export var _project_list : VBoxContainer

func _ready() -> void:
	add_project_button.pressed.connect(func(): EventBus.drag_and_drop_window_enable.emit())
	EventBus.ui_project_list_updated.connect(_check_visibility)
	EventBus.project_removed.connect(_check_visibility)
	EventBus.project_found.connect(func(_path): _check_visibility())
	_check_visibility()

func _check_visibility() -> void:
	if SaveSystem.get_all_projects().size() > 0 or _project_list.get_child_count() > 1:
		_hint.hide()
		_project_list.show()
	else:
		_hint.show()
		_project_list.hide()
"

[sub_resource type="GDScript" id="GDScript_2toya"]
script/source = "extends VBoxContainer

@export var project_panel_scene : PackedScene = preload(\"res://nodes/UI/project_panel.tscn\")
@export var path_system_node : Node 

func _ready() -> void:
	EventBus.project_found.connect(_on_project_found)
	_load_existing_projects()
	EventBus.ui_project_list_updated.connect(_load_existing_projects)

func _on_project_found(project_file_path: String) -> void:
	var clean_path = project_file_path.simplify_path()
	var project_id = str(clean_path.hash())
	if SaveSystem.get_all_projects().has(project_id): return
	SaveSystem.add_project(project_file_path)
	_create_panel(project_id)

func _load_existing_projects() -> void:
	var all_projects = SaveSystem.get_all_projects()
	for child in get_children(): if child is panel_base: child.queue_free()
	for project_id in all_projects: _create_panel(project_id)

## Spawn project panel
func _create_panel(project_id: String) -> void:
	var data = SaveSystem.get_project_by_id(project_id)
	if data.is_empty(): return
	var full_path = data[\"path\"]
	var is_missing = not FileAccess.file_exists(full_path)
	
	var p_name = data.get(\"name\", \"Unnamed Project\") 
	var p_dir = full_path.get_base_dir()
	var p_version = data.get(\"version\", \"\") 
	
	if not is_missing:
		var config = ConfigFile.new()
		if config.load(full_path) == OK:
			p_name = config.get_value(\"application\", \"config/name\", \"Unnamed Project\")
			SaveSystem.update_project_name(project_id, p_name)
			if p_version.is_empty() or p_version == \"Unknown\":
				p_version = _extract_version(config)
				SaveSystem.update_project_version(project_id, p_version)
	
	if p_version.is_empty(): p_version = \"Unknown\"
	
	var panel = project_panel_scene.instantiate()
	add_child(panel)
	var target_index = max(0, get_child_count() - 2)
	move_child(panel, target_index)
	
	panel.set_text(p_name)
	panel.set_project_path(p_dir)
	panel.set_version(p_version)
	panel.set_id(project_id)
	panel.setup_tags()
	
	if panel.has_method(\"setup_project_data\"): panel.setup_project_data(project_id, data)
	else: panel.setup_icon()
	
	if is_missing and panel.has_method(\"set_missing_state\"): panel.set_missing_state()

func _extract_version(config: ConfigFile) -> String:
	if config.has_section_key(\"application\", \"config/features\"):
		var features = config.get_value(\"application\", \"config/features\")
		for feature in features:
			if feature.is_valid_float() or (feature.length() > 0 and feature[0].is_numeric()):
				return feature
	return \"Unknown\"
"

[sub_resource type="GDScript" id="GDScript_eedq5"]
script/source = "extends Control

@export_category(\"Buttons\")
@export var add_godot_engine_button : Button

@export var _hint : Label
@export var _godot_versions : VBoxContainer

func _ready() -> void:
	_hint_refresh()
	add_godot_engine_button.pressed.connect(EventBus.godot_engine_download_window_enable.emit)
	EventBus.godot_installed_version_changed.connect(_hint_refresh)

func _hint_refresh() -> void:
	if VersionControl.get_all_versions().is_empty(): 
		_hint.show()
		_godot_versions.hide()
	else:
		_hint.hide()
		_godot_versions.show()
"

[sub_resource type="GDScript" id="GDScript_2ykvb"]
script/source = "extends VBoxContainer

@export var panel_scene: PackedScene = preload(\"res://nodes/UI/godot_version_panel.tscn\")

func _ready() -> void:
	EventBus.version_update.connect(refresh_list)
	refresh_list()

func refresh_list() -> void:
	for child in get_children(): if child is panel_base: child.queue_free()
	
	var versions = VersionControl.get_all_versions()
	var version_keys = versions.keys() if versions is Dictionary else versions.duplicate()
	
	version_keys.sort_custom(func(a: String, b: String) -> bool:
		var a_parts = a.split(\"_\")[0].split(\".\")
		var b_parts = b.split(\"_\")[0].split(\".\")
		var max_len = max(a_parts.size(), b_parts.size())
		for i in range(max_len):
			var a_val = a_parts[i].to_int() if i < a_parts.size() else 0
			var b_val = b_parts[i].to_int() if i < b_parts.size() else 0
			if a_val != b_val: return a_val > b_val
		return false
	)
	
	for version_key in version_keys: _create_panel(version_key)

func _create_panel(version_key: String) -> void:
	var instance = panel_scene.instantiate()
	add_child(instance)
	var target_index = max(1, get_child_count() - 2)
	move_child(instance, target_index)
	var display_name = VersionControl.get_engine_name(version_key)
	instance.set_text(display_name)
	if instance.has_method(\"set_version_id\"): instance.set_version_id(version_key)
"

[sub_resource type="GDScript" id="GDScript_d4yno"]
script/source = "extends Control

@export_category(\"Blur\")
@export var _blur : ColorRect

@export_category(\"Windows\")
@export var _drag_and_drop_window : Control
@export var _settings_window : Control
@export var _get_new_version_window : Control
@export var _fix_path_window : Control
@export var _swich_project_version : Control
@export var _new_icon_window : Control

func _ready() -> void:
	hide()
	
	_settings_window.close_window.connect(disable)
	_drag_and_drop_window.close_window.connect(disable)
	_get_new_version_window.close_window.connect(disable)
	_fix_path_window.close_window.connect(disable)
	_swich_project_version.close_window.connect(disable)
	_new_icon_window.close_window.connect(disable)
	
	EventBus.settings_window_enable.connect(enable_settings)
	EventBus.drag_and_drop_window_enable.connect(enable_drag_and_drop)
	EventBus.godot_engine_download_window_enable.connect(enable_get_engine_version)
	EventBus.fix_path_activate.connect(enable_fix_path_window)
	EventBus.version_change.connect(enable_swich_project_version)
	EventBus.change_icon_required.connect(enable_icon_change_window)

func enable_swich_project_version(_project_id : String) -> void:
	enable()
	_swich_project_version.enable(_project_id)

func enable_icon_change_window(_project_id : String) -> void:
	enable()
	_new_icon_window._icon_change_enable(_project_id)

func enable_fix_path_window(_id : String, is_engine_mode : bool) -> void:
	enable()
	_fix_path_window.setup_fix_window(_id, is_engine_mode)

func enable_get_engine_version() -> void:
	enable()
	_get_new_version_window.enable()

func enable_settings() -> void:
	enable()
	_settings_window.enable()

func enable_drag_and_drop() -> void:
	enable()
	_drag_and_drop_window.enable()

func enable_blur() -> void:
	_blur.enable()

func disable_windows() -> void:
	_drag_and_drop_window.disable()
	_settings_window.disable()
	_get_new_version_window.disable()
	_fix_path_window.disable()
	_swich_project_version.disable()
	_new_icon_window.disable()

func disable_blur() -> void:
	_blur.disable()

func disable_all() -> void:
	disable_windows()
	disable_blur()

func enable() -> void:
	EventBus.activate_window_or_switch.emit()
	show()

func disable() -> void:
	hide()
"

