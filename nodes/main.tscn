[sub_resource type="GDScript" id="GDScript_vr02l"]
script/source = "extends Node

@export_category(\"Buttons\")
@export var _scan_projects_button : Button
@export var _close_window_button : Button

@export_category(\"Dialogs\")
@export var _file_dialog : FileDialog

@export_category(\"DropZone\")
@export var drop_zone : Control

@export_category(\"UI\")
@export var _progress_bar : TextureProgressBar

var _scan_thread: Thread
var _total_dirs: float = 0.0
var _scanned_dirs: float = 0.0

func _ready() -> void:
	_file_dialog.file_mode = FileDialog.FILE_MODE_OPEN_DIR
	_file_dialog.access = FileDialog.ACCESS_FILESYSTEM
	_file_dialog.canceled.connect(_disable_buttons.bind(false))
	_file_dialog.canceled.connect(drop_zone.can_drop.bind(true))
	_scan_projects_button.pressed.connect(_on_scan_projects_pressed)
	_file_dialog.dir_selected.connect(_on_dir_selected)

func _on_scan_projects_pressed() -> void:
	_disable_buttons(true)
	drop_zone.can_drop(false)
	_file_dialog.popup_centered_ratio(0.5)

func _disable_buttons(_value : bool) -> void:
	_close_window_button.disabled = _value
	_scan_projects_button.disabled = _value

func _on_dir_selected(path: String) -> void:
	if _scan_thread and _scan_thread.is_alive():
		return
	_disable_buttons(true)
	_progress_bar.show()
	_scan_projects_button.text = \"  \"
	_scan_thread = Thread.new()
	_scan_thread.start(_process_scan_threaded.bind(path))

func _process_scan_threaded(path: String) -> void:
	_total_dirs = 0.0
	_scanned_dirs = 0.0
	_count_dirs_recursive(path)
	if _total_dirs > 0:
		_scan_recursive(path)
	call_deferred(\"_on_scan_completed\")

func _count_dirs_recursive(path: String) -> void:
	var dir = DirAccess.open(path)
	if not dir: return
	_total_dirs += 1
	dir.list_dir_begin()
	var file_name = dir.get_next()
	
	while file_name != \"\":
		if dir.current_is_dir() and not file_name.begins_with(\".\"):
			_count_dirs_recursive(path.path_join(file_name))
		file_name = dir.get_next()
	dir.list_dir_end()

func _scan_recursive(path: String) -> void:
	_scanned_dirs += 1
	var percent = (_scanned_dirs / _total_dirs) * 100.0
	_progress_bar.update_progress.call_deferred(percent)
	var dir = DirAccess.open(path)
	if not dir: return
	
	if dir.file_exists(\"project.godot\"):
		var full_config_path = path.path_join(\"project.godot\")
		call_deferred(\"_register_project\", full_config_path)
		return
	dir.list_dir_begin()
	var file_name = dir.get_next()
	
	while file_name != \"\":
		if dir.current_is_dir():
			if not file_name.begins_with(\".\"): 
				_scan_recursive(path.path_join(file_name))
		file_name = dir.get_next()
	dir.list_dir_end()

func _register_project(full_path: String) -> void:
	EventBus.project_found.emit(full_path)
	print(\"Project was found in path: \", full_path)

func _on_scan_completed() -> void:
	if _scan_thread:
		_scan_thread.wait_to_finish()
	print(\"Scan is completed\")
	_scan_projects_button.text = \"Сканировать\"
	_disable_buttons(false)
	drop_zone.can_drop(true)
	_progress_bar.update_progress(0.0)
	_progress_bar.hide()
	_close_window_button.pressed.emit()
"

