[sub_resource type="GDScript" id="GDScript_ugtvp"]
script/source = "extends Node

const ENGINE_FOLDER: String = \"user://engines/\"

@export var _scan_engine_button: Button
@export var _close_button : Button

func _ready() -> void:
	_scan_engine_button.pressed.connect(_open_system_file_dialog)

func _open_system_file_dialog() -> void:
	var filters := PackedStringArray()
	if OS.get_name() == \"Windows\": filters.append(\"*.exe ; Godot Executable\")
	else:
		filters.append(\"*.x86_64, *.arm64 ; Godot Executable\")
		filters.append(\"* ; All Files\")
	_disable_buttons(true)
	DisplayServer.file_dialog_show(
		\"Выберите исполняемый файл Godot\", 
		OS.get_system_dir(OS.SYSTEM_DIR_DESKTOP), 
		\"\", 
		false, 
		DisplayServer.FILE_DIALOG_MODE_OPEN_FILE, 
		filters, 
		_on_file_selected
	)

func _disable_buttons(_value : bool):
	_scan_engine_button.disabled = _value
	_close_button.disabled = _value

func _on_file_selected(status: bool, selected_paths: PackedStringArray, _selected_filter_index: int) -> void:
	_disable_buttons(false)
	if not status or selected_paths.is_empty(): return 
	var exe_path = selected_paths[0]
	_process_imported_engine(exe_path)

func _process_imported_engine(source_path: String) -> void:
	var engine_version = _get_external_godot_version(source_path)
	if engine_version.is_empty():
		printerr(\"ERROR: This file isn't Godot Engine.\")
		return
	var pure_version = engine_version.replace(\"Godot engine \", \"\").strip_edges()
	var base_version_key = pure_version + \"_custom\"
	var version_key = base_version_key
	var existing_versions = VersionControl.get_all_versions()
	if existing_versions.has(version_key): 
		version_key = base_version_key + \"_\" + str(Time.get_ticks_msec() % 10000)
	
	var version_dir = ENGINE_FOLDER.path_join(version_key)
	if not DirAccess.dir_exists_absolute(version_dir): 
		DirAccess.make_dir_recursive_absolute(version_dir)
	
	var file_name = source_path.get_file()
	var target_path = version_dir.path_join(file_name)
	
	var err = DirAccess.copy_absolute(source_path, target_path)
	if err != OK:
		printerr(\"ERROR: Failed to copy engine file: \", err)
		return
	if OS.get_name() != \"Windows\": OS.execute(\"chmod\", [\"+x\", ProjectSettings.globalize_path(target_path)])
	
	var global_exe_path = ProjectSettings.globalize_path(target_path)
	var custom_name = \"Custom Build \" + pure_version
	VersionControl.add_engine_version(version_key, global_exe_path, custom_name, \"\")
	EventBus.version_update.emit()
	print(\"Success: Imported engine saved as '\", version_key, \"'.\")

func _get_external_godot_version(exe_path: String) -> String:
	var output := []
	var exit_code: int = OS.execute(exe_path, [\"--version\"], output, true)
	if exit_code == 0 and output.size() > 0: return output[0].strip_edges()
	return \"\"
"

[sub_resource type="GDScript" id="GDScript_5fgky"]
script/source = "extends Control

signal close_window

@export_category(\"Buttons\")
@export var _fix_button : Button
@export var _close_button : Button

@export_category(\"Labels\")
@export var _error_description : Label
@export var _path_hint : Label

var id: String = \"\"
var _is_engine_mode : bool = false

var _file_dialog: FileDialog

func _ready() -> void:
	_close_button.pressed.connect(disable)
	_fix_button.pressed.connect(_fix)
	_setup_file_dialog()
	hide()

func _setup_file_dialog() -> void:
	_file_dialog = FileDialog.new()
	_file_dialog.file_mode = FileDialog.FILE_MODE_OPEN_FILE
	_file_dialog.access = FileDialog.ACCESS_FILESYSTEM
	if \"use_native_dialog\" in _file_dialog: _file_dialog.set(\"use_native_dialog\", true)
	
	_file_dialog.file_selected.connect(_on_file_selected)
	_file_dialog.canceled.connect(_cancel_search)
	add_child(_file_dialog)

func _set_engine_path_error_text() -> void:
	_error_description.modulate = Color.WHITE
	_error_description.text = tr(\"#err_engine_moved\") + \" \" + str(id) + \" \" + tr(\"#err_engine_moved_after_message\")
	_path_hint.text = \".../godot_engine_\" + id
	if OS.get_name() == \"Windows\": _path_hint.text = _path_hint.text + \".exe\"

func _set_project_path_error_text() -> void:
	_error_description.modulate = Color.WHITE
	_error_description.text = \"#err_project_moved\"
	_path_hint.text = \".../\" + SaveSystem.get_project_name(id)

func enable() -> void: show()

func disable() -> void: 
	hide()
	id = \"\"
	close_window.emit()

func _fix() -> void:
	_file_dialog.clear_filters()
	
	if _is_engine_mode: 
		if OS.get_name() == \"Windows\": _file_dialog.add_filter(\"*.exe\", \"Исполняемые файлы Godot\")
		elif OS.get_name() == \"macOS\": _file_dialog.add_filter(\"*.app\", \"Приложения Godot\")
	else: _file_dialog.add_filter(\"project.godot\", \"Файл проекта Godot\")
		
	_file_dialog.popup_centered_ratio(0.5)
	_disable_buttons(true)

func _disable_buttons(value : bool) -> void:
	_fix_button.disabled = value
	_close_button.disabled = value

func _cancel_search() -> void:
	_disable_buttons(false)

func _on_file_selected(path: String) -> void:
	if _is_engine_mode:
		if _verify_engine_version(path, id):
			var current_name = VersionControl.get_engine_name(id)
			var current_icon = VersionControl.get_engine_icon(id)
			VersionControl.add_engine_version(id, path, current_name, current_icon)
			EventBus.version_update.emit()
			disable()
		else:
			_error_description.text = tr(\"#err_invalid_engine_ver\") + \" \" + id + \" \" + \".\\n\" + tr(\"#err_select_correct_file\")
			_error_description.modulate = Color.RED
			_disable_buttons(false)
	else:
		var expected_name: String = SaveSystem.get_project_by_id(id).get(\"name\", \"\")
		var config := ConfigFile.new()
		
		if config.load(path) == OK:
			var selected_name: String = config.get_value(\"application\", \"config/name\", \"\")
			if selected_name == expected_name or expected_name == \"\" or expected_name == \"Unnamed Project\":
				SaveSystem.update_project_path(id, path)
				_disable_buttons(false)
				disable()
				EventBus.ui_project_list_updated.emit()
				
			else:
				_error_description.text = tr(\"#err_project_mismatch\") + selected_name + tr(\"#err_project_mismatch_after_message\") + expected_name + \"».\"
				_error_description.modulate = Color.RED
				_disable_buttons(false)
		else:
			_error_description.text = \"#err_read_project_file\"
			_error_description.modulate = Color.RED
			_disable_buttons(false)

func _verify_engine_version(path: String, expected_id: String) -> bool:
	var exec_path: String = path
	
	if OS.get_name() == \"macOS\" and path.ends_with(\".app\"):
		exec_path = path.path_join(\"Contents/MacOS/Godot\")
		if not FileAccess.file_exists(exec_path): return false
	var file_name: String = exec_path.get_file().to_lower()
	if not \"godot\" in file_name: return false
	var file = FileAccess.open(exec_path, FileAccess.READ)
	if file:
		var size_mb: float = file.get_length() / 1048576.0
		file.close()
		if size_mb < 10.0: return false
	else: return false
	var output: Array = []
	var exit_code: int = OS.execute(exec_path, [\"--version\"], output)
	
	if exit_code != 0 or output.is_empty(): return false
	var version_output: String = output[0].strip_edges()
	var base_id: String = expected_id.get_slice(\"-\", 0).replace(\"v\", \"\")
	return version_output.begins_with(base_id)

func setup_fix_window(engine_id : String, is_engine_mode : bool) -> void:
	id = engine_id
	_error_description.modulate = Color.WHITE
	_is_engine_mode = is_engine_mode
	if _is_engine_mode: _set_engine_path_error_text()
	else: _set_project_path_error_text()
	enable()
"

[sub_resource type="GDScript" id="GDScript_sncrj"]
script/source = "extends Control

@export var _attantion_window : Panel
@export var _chosing_another_version : Panel

signal close_window

var _id : String = \"\"

func _ready() -> void:
	_id = \"\"
	hide()
	_attantion_window.close_window.connect(disable)
	_attantion_window.activate_chosing_another_window.connect(switch_window_chosing_another_version)
	_chosing_another_version.close_window.connect(disable)

func enable(id : String) -> void:
	_id = id
	_chosing_another_version.hide()
	_attantion_window.enable(_id)
	show()

func disable() -> void:
	_id = \"\"
	_attantion_window.hide()
	_chosing_another_version.hide()
	close_window.emit()
	hide()

func switch_window_chosing_another_version():
	_attantion_window.hide()
	_chosing_another_version.enable(_id)
"

[sub_resource type="GDScript" id="GDScript_xxyh6"]
script/source = "extends Panel

signal close_window
signal activate_chosing_another_window

@export var _close_button : Button
@export var _next_button : Button
@export var _backup_button : Button
@export var _backup_system : Node
@export var _progress_bar : TextureProgressBar
@export var _path_hint : Label

var _id : String = \"\"

func _ready() -> void:
	_id = \"\"
	hide()
	_close_button.pressed.connect(disable)
	_next_button.pressed.connect(activate_chosing_another_window.emit)
	_backup_button.pressed.connect(_start_backup)
	_backup_system.backup_progress.connect(_progress_bar.update_progress)
	_backup_system.backup_finished.connect(_on_backup_finished)

func enable(id : String) -> void:
	_id = id
	var full_text : String = \".../\" + SaveSystem.get_project_name(_id)
	_path_hint.text = full_text.left(40) + \"...\" if full_text.length() > 40 else full_text
	show()

func disable() -> void:
	_id = \"\"
	close_window.emit()
	hide()

func _start_backup() -> void:
	_progress_bar.update_progress(0.0) 
	
	_backup_button.disabled = true
	_next_button.disabled = true
	_close_button.disabled = true
	_backup_button.text = \"  \"
	_backup_system.create_backup_async(_id)

@warning_ignore(\"unused_parameter\")
func _on_backup_finished(new_id: String) -> void:
	_backup_button.disabled = false
	_next_button.disabled = false
	_close_button.disabled = false
	_backup_button.text = \"#label_backup\"
	_progress_bar.hide()
"

[sub_resource type="GDScript" id="GDScript_p41y5"]
script/source = "extends Node

signal backup_started
signal backup_progress(percent: float)
signal backup_finished(new_project_id: String)

var _backup_thread: Thread
var _total_files: int = 0
var _copied_files: int = 0

func create_backup_async(project_id: String) -> void:
	if _backup_thread and _backup_thread.is_alive():
		printerr(\"The copy flow is already running.\")
		return
		
	var project_data = SaveSystem.get_project_by_id(project_id)
	if project_data.is_empty():
		printerr(\"Project with '\", project_id, \"' ID not found.\")
		return
	
	var original_file_path: String = project_data.get(\"path\", \"\")
	var original_name: String = project_data.get(\"name\", \"Unnamed Project\")
	
	if original_file_path.is_empty():
		printerr(\"Project '\", original_name, \"' has empty path.\")
		return
		
	var original_dir: String = original_file_path.get_base_dir()
		
	if not DirAccess.dir_exists_absolute(original_dir):
		printerr(\"The source directory does not exist on the disk: \", original_dir)
		return

	var time = Time.get_datetime_dict_from_system()
	var time_string = \"%04d%02d%02d_%02d%02d%02d\" % [time.year, time.month, time.day, time.hour, time.minute, time.second]
	
	var backup_name = original_name + \" backup (\" + time_string + \")\"
	var backup_dir = original_dir + \"_backup_\" + time_string 
	
	var new_project_file_path = backup_dir + \"/\" + original_file_path.get_file()
	
	var thread_data = {
		\"src\": original_dir,
		\"dest\": backup_dir,
		\"name\": backup_name,
		\"register_path\": new_project_file_path
	}
	
	_backup_thread = Thread.new()
	backup_started.emit()
	_backup_thread.start(_perform_backup.bind(thread_data))

func _perform_backup(data: Dictionary) -> void:
	_total_files = _count_files_recursive(data[\"src\"])
	_copied_files = 0
	
	var err = _copy_dir_recursive(data[\"src\"], data[\"dest\"])
	
	if err == OK:
		var update_err = _update_project_name_in_file(data[\"register_path\"], data[\"name\"])
		if update_err != OK:
			printerr(\"Attention: The internal name in the project file could not be updated.godot. Code: \", update_err)
	
	call_deferred(\"_on_backup_completed\", err, data[\"register_path\"], data[\"name\"])

## edit INI file
func _update_project_name_in_file(file_path: String, new_name: String) -> Error:
	var config = ConfigFile.new()
	var err = config.load(file_path)
	
	if err != OK: return err
	
	config.set_value(\"application\", \"config/name\", new_name)
	return config.save(file_path)

func _on_backup_completed(err: Error, register_path: String, backup_name: String) -> void:
	if _backup_thread.is_started():
		_backup_thread.wait_to_finish()
	if err == OK:
		SaveSystem.add_project(register_path, backup_name)
		var clean_path = register_path.replace(\"\\\\\", \"/\").simplify_path()
		var new_id = str(clean_path.hash())
		EventBus.ui_project_list_updated.emit()
		
		print(\"Success: Backup saved and registered on the way \", register_path)
		backup_finished.emit(new_id)
	else:
		printerr(\"Critical error when copying files: Code \", err)
		backup_finished.emit(\"\") 

func _count_files_recursive(dir_path: String) -> int:
	var count = 0
	var dir = DirAccess.open(dir_path)
	if not dir: return count
	
	dir.list_dir_begin()
	var file_name = dir.get_next()
	while file_name != \"\":
		if file_name == \".\" or file_name == \"..\":
			file_name = dir.get_next()
			continue
			
		var full_path = dir_path + \"/\" + file_name
		if dir.current_is_dir():
			count += _count_files_recursive(full_path)
		else:
			count += 1
		file_name = dir.get_next()
		
	return count

func _copy_dir_recursive(from_dir: String, to_dir: String) -> Error:
	var dir = DirAccess.open(from_dir)
	if not dir: return FAILED
		
	DirAccess.make_dir_recursive_absolute(to_dir)
	dir.list_dir_begin()
	var file_name = dir.get_next()
	
	while file_name != \"\":
		if file_name == \".\" or file_name == \"..\":
			file_name = dir.get_next()
			continue
			
		var src_path = from_dir + \"/\" + file_name
		var dest_path = to_dir + \"/\" + file_name
		
		if dir.current_is_dir():
			var err = _copy_dir_recursive(src_path, dest_path)
			if err != OK: return err
		else:
			var err = DirAccess.copy_absolute(src_path, dest_path)
			if err != OK: return err
			
			_copied_files += 1
			if _total_files > 0:
				var percent = (float(_copied_files) / float(_total_files)) * 100.0
				backup_progress.emit.call_deferred(percent)
			
		file_name = dir.get_next()
		
	return OK
"

[sub_resource type="GDScript" id="GDScript_aj8fh"]
script/source = "extends Panel

signal close_window

@export var _close_button : Button
@export var _path_hint : Label
@export var _option_button : OptionButton
@export var _update_version : Button

var _id : String = \"\"
var _version : String = \"\"

func _ready() -> void:
	_id = \"\"
	hide()
	_option_button._on_version_selected.connect(_new_version_selected)
	_close_button.pressed.connect(disable)
	_update_version.pressed.connect(_on_update_version_pressed)

func _new_version_selected(_new_version : String) -> void:
	_version = _new_version

func enable(id : String) -> void: 
	_id = id
	var full_text : String = \".../\" + SaveSystem.get_project_name(_id)
	_path_hint.text = full_text.left(40) + \"...\" if full_text.length() > 40 else full_text
	
	if _option_button.has_method(\"enable\"):
		_option_button.enable()
	show()

func disable() -> void: 
	_id = \"\"
	hide()
	close_window.emit()

func _on_update_version_pressed() -> void:
	if _id.is_empty() or _version.is_empty(): return
	var engine_path : String = VersionControl.get_godot_path(_version)
	
	if engine_path.is_empty() or not FileAccess.file_exists(engine_path):
		if _option_button.has_method(\"_refresh_versions\"):
			_option_button._refresh_versions()
		return
	SaveSystem.update_project_version(_id, _version)
	var project_path : String = SaveSystem.get_project_by_id(_id).get(\"path\", \"\")
	
	if not project_path.is_empty():
		var dir_path: String = project_path
		if project_path.ends_with(\"project.godot\"):
			dir_path = project_path.get_base_dir()
		OS.create_process(engine_path, [\"-e\", \"--path\", dir_path])
	get_tree().quit()
"

[sub_resource type="GDScript" id="GDScript_n8d6l"]
script/source = "extends OptionButton

signal _on_version_selected(varsion : String)

func _ready() -> void:
	EventBus.godot_installed_version_changed.connect(_refresh_versions)
	item_selected.connect(_on_item_selected)
	_refresh_versions()

func _refresh_versions() -> void:
	clear()
	var versions: Array = VersionControl.get_sorted_versions()
	
	if versions.is_empty():
		set_item_disabled(0, true)
		return
		
	for i in range(versions.size()):
		var version_id: String = versions[i]
		add_item(version_id)

func enable() -> void:
	if item_count > 0:
		_on_item_selected(0)

func _on_item_selected(index: int) -> void:
	var selected_version_id: String = get_item_text(index)
	_on_version_selected.emit(selected_version_id)
	print(\"User choose verion: \", selected_version_id)
"

