[sub_resource type="GDScript" id="GDScript_t4bcl"]
script/source = "extends Panel

@export var _view_window : Panel
@export_category(\"buttons\")
@export var _godot_hub_button : Button
@export var _lineseedjp_button : Button
@export var _godot_engine_button : Button
@export var _about_program_button : Button
@export var _close_about_window_button : Button
@export var _update_button : Button

func _ready() -> void:
	hide()
	_update_button.hide()
	_close_about_window_button.pressed.connect(_on_close_about_window_button_pressed)
	var buttons = [
		_godot_hub_button, 
		_lineseedjp_button, 
		_godot_engine_button, 
		_about_program_button
	]
	
	for btn in buttons: _connect_license_button(btn)

func _connect_license_button(btn: Button) -> void:
	if btn:
		btn.pressed.connect(func():
			var id_from_button = btn.get(\"ID\")
			if id_from_button != null:
				_view_window.text_update(id_from_button)
		)

func _on_close_about_window_button_pressed() -> void:
	disable()

func enable() -> void:
	_connect_license_button(_godot_hub_button)
	show()

func disable() -> void:
	hide()
"

[sub_resource type="GDScript" id="GDScript_t5vdr"]
script/source = "extends Node

signal progress_updated(percent: float)

const GITHUB_API_URL = \"https://api.github.com/repos/horityfoxy/GodotHub/releases/latest\"

var api_request: HTTPRequest
var download_request: HTTPRequest
var update_zip_path = \"user://update_temp.zip\"
var _latest_release_data: Dictionary

@export var update_button: Button
@export var progress_bar: TextureProgressBar

var _is_downloading: bool = false

func _ready() -> void:
	update_button.hide()
	progress_updated.connect(progress_bar.update_progress)
	if VersionControl.is_internet_allowed(): _start_update_process()
	else: VersionControl.internet_allowed.connect(_start_update_process)

func _start_update_process() -> void:
	api_request = HTTPRequest.new()
	add_child(api_request)
	api_request.request_completed.connect(_on_api_response)
	download_request = HTTPRequest.new()
	add_child(download_request)
	download_request.request_completed.connect(_on_download_completed)
	check_for_updates()

func check_for_updates() -> void:
	if api_request.request(GITHUB_API_URL) != OK: push_error(\"GitHub API request failed.\")

func _on_api_response(_result: int, response_code: int, _headers: PackedStringArray, body: PackedByteArray) -> void:
	if response_code == 200:
		var json = JSON.parse_string(body.get_string_from_utf8())
		if json and json.has(\"tag_name\"):
			var latest_version = json[\"tag_name\"].trim_prefix(\"v\")
			if _is_version_newer(latest_version, VersionControl.version):
				print(\"Update found: v\", latest_version)
				_latest_release_data = json
				if update_button:
					update_button.show()
					if not update_button.pressed.is_connected(_on_update_button_pressed):
						update_button.pressed.connect(_on_update_button_pressed)
	else: push_error(\"API Error: \", response_code)

func _is_version_newer(latest: String, current: String) -> bool:
	var l_parts = latest.split(\".\")
	var c_parts = current.split(\".\")
	var max_len = max(l_parts.size(), c_parts.size())
	for i in range(max_len):
		var l_val = l_parts[i].to_int() if i < l_parts.size() else 0
		var c_val = c_parts[i].to_int() if i < c_parts.size() else 0
		if l_val > c_val: return true
		elif l_val < c_val: return false
	return false

func _on_update_button_pressed() -> void:
	if update_button:
		update_button.disabled = true
		update_button.text = \"  \"
	_start_download(_latest_release_data)

func _start_download(json_data: Dictionary) -> void:
	if not json_data.has(\"assets\") or json_data[\"assets\"].size() == 0:
		push_error(\"No assets in release.\")
		return
	var current_os = OS.get_name()
	var target_keyword = \"Windows\" if current_os == \"Windows\" else \"Linux\"
	var download_url = \"\"
	for asset in json_data[\"assets\"]:
		var asset_name = asset.get(\"name\", \"\")
		if asset_name.contains(target_keyword):
			download_url = asset.get(\"browser_download_url\", \"\")
			break
	if download_url == \"\":
		push_error(\"Asset for \" + target_keyword + \" not found.\")
		return
	download_request.download_file = update_zip_path
	var err = download_request.request(download_url)
	if err == OK: _is_downloading = true 

func _on_download_completed(_result: int, response_code: int, _headers: PackedStringArray, _body: PackedByteArray) -> void:
	_is_downloading = false
	if response_code == 200 or response_code == 201: _unpack_and_install()

func _process(_delta: float) -> void:
	if _is_downloading and download_request.get_body_size() > 0:
		var downloaded = download_request.get_downloaded_bytes()
		var total = download_request.get_body_size()
		var percent = (float(downloaded) / float(total)) * 90.0
		progress_updated.emit(percent)

func _unpack_and_install() -> void:
	var base_dir = OS.get_executable_path().get_base_dir()
	var temp_extract_dir = base_dir.path_join(\"update_extracted\")
	if DirAccess.dir_exists_absolute(temp_extract_dir):
		OS.move_to_trash(ProjectSettings.globalize_path(temp_extract_dir))
	DirAccess.make_dir_recursive_absolute(temp_extract_dir)
	var reader = ZIPReader.new()
	if reader.open(update_zip_path) != OK:
		push_error(\"Не удалось открыть ZIP-архив.\")
		return
	var files = reader.get_files()
	var total_files = files.size()
	var current_file = 0
	for file_name in files:
		var target_path = temp_extract_dir.path_join(file_name)
		if file_name.ends_with(\"/\"):
			DirAccess.make_dir_recursive_absolute(target_path)
			continue
		var parent_dir = target_path.get_base_dir()
		if not DirAccess.dir_exists_absolute(parent_dir):
			DirAccess.make_dir_recursive_absolute(parent_dir)
		var content = reader.read_file(file_name)
		var f = FileAccess.open(target_path, FileAccess.WRITE)
		if f:
			f.store_buffer(content)
			f.close()
		current_file += 1
		if current_file % 10 == 0:
			var percent = 90.0 + ((float(current_file) / float(total_files)) * 10.0)
			progress_updated.emit(percent)
			await get_tree().process_frame 
	reader.close()
	progress_updated.emit(100.0, \"\")
	await get_tree().create_timer(0.5).timeout
	if FileAccess.file_exists(update_zip_path):
		DirAccess.remove_absolute(update_zip_path)
	_run_updater(base_dir, temp_extract_dir)

func _run_updater(base_dir: String, temp_dir: String) -> void:
	var exe_path = OS.get_executable_path()
	var exe_name = exe_path.get_file()
	if OS.get_name() == \"Windows\": _create_windows_updater(base_dir, temp_dir, exe_name)
	else: _create_linux_sh(base_dir, temp_dir, exe_name)
	get_tree().quit()

func _create_windows_updater(base_dir: String, temp_dir: String, exe_name: String) -> void:
	var ps_path = base_dir.path_join(\"updater.ps1\")
	var td = temp_dir.replace(\"/\", \"\\\\\")
	var bd = base_dir.replace(\"/\", \"\\\\\")
	var exe_full = base_dir.path_join(exe_name).replace(\"/\", \"\\\\\")

	var ps_content = \"\"\"$exeName = '%s'
$tempDir = '%s'
$baseDir = '%s'
$exePath = '%s'

while ($true) {
    $running = Get-Process -ErrorAction SilentlyContinue | Where-Object {
        try { $_.MainModule.FileName -eq $exePath } catch { $false }
    }
    if (-not $running) { break }
    Start-Sleep -Seconds 1
}

Start-Sleep -Seconds 1
Copy-Item -Path \"$tempDir\\\\*\" -Destination $baseDir -Recurse -Force
Remove-Item -Path $tempDir -Recurse -Force
Start-Process $exePath
Remove-Item $MyInvocation.MyCommand.Path -Force
\"\"\" % [exe_name, td, bd, exe_full]

	var f = FileAccess.open(ps_path, FileAccess.WRITE)
	if f:
		f.store_buffer(PackedByteArray([0xEF, 0xBB, 0xBF]))  # UTF-8 BOM
		f.store_string(ps_content)
		f.close()

	var global_ps_path = ProjectSettings.globalize_path(ps_path)
	OS.create_process(\"powershell.exe\", [
		\"-ExecutionPolicy\", \"Bypass\",
		\"-NonInteractive\",
		\"-WindowStyle\", \"Hidden\",
		\"-File\", global_ps_path
	])

func _create_linux_sh(base_dir: String, temp_dir: String, exe_name: String) -> void:
	var sh_path = base_dir.path_join(\"updater.sh\")
	var sh_content = \"\"\"#!/bin/bash
sleep 2
cp -rn \"%s/\"* \"%s/\"
rm -rf \"%s\"
chmod +x \"%s\"
\"%s\" &
rm -- \"$0\"
\"\"\" % [temp_dir, base_dir, temp_dir, base_dir.path_join(exe_name), base_dir.path_join(exe_name)]
	var f = FileAccess.open(sh_path, FileAccess.WRITE)
	f.store_string(sh_content)
	f.close()
	OS.execute(\"chmod\", [\"+x\", sh_path])
	OS.create_process(\"/bin/bash\", [sh_path])
"

