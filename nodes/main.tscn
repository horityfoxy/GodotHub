[sub_resource type="GDScript" id="GDScript_pel7g"]
script/source = "extends CanvasLayer

# Example usage:
# func _ready() -> void:
	#To launch a specific project:
	#launch_godot(\"C:/Path/To/Godot.exe\", \"C:/Path/To/Project\")
	#
	# To launch just the engine (Project Manager):
	#launch_godot(\"C:/Path/To/Godot.exe\", \"\")

func launch_godot(godot_path: String, project_dir: String = \"\") -> void:
	# Check if the executable exists
	if not FileAccess.file_exists(godot_path):
		printerr(\"ERROR: Godot executable not found at: \", godot_path)
		return
	
	var args: PackedStringArray = []
	
	# Check if we need to open a specific project or just the Project Manager
	if project_dir != \"\":
		args.append(\"--path\")
		args.append(project_dir)
		args.append(\"-e\") # Opens the editor directly
	
	# Start the process without blocking the hub
	var pid: int = OS.create_process(godot_path, args)
	
	if pid > 0:
		print(\"Process started successfully. PID: \", pid)
		# Close the Hub application to save resources
		get_tree().quit()
	else:
		printerr(\"ERROR: Failed to launch the process.\")
"

