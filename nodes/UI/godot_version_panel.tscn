[sub_resource type="GDScript" id="GDScript_2r1el"]
script/source = "extends panel_base

var _version_id: String = \"\"

@export var _launch_button: Button
@export var _problem_detected_button: Button
@export var _hint: RichTextLabel
@export var _texture_bar : TextureProgressBar

func _ready() -> void:
	_launch_button.disabled = true
	_remove_button.hide()
	_launch_button.pressed.connect(_launch_engine_version)
	super()

func set_version_id(v_id: String) -> void:
	_version_id = v_id
	_check_engine_path()

func _check_engine_path() -> void:
	var godot_path = VersionControl.get_godot_path(_version_id)
	if not godot_path.is_empty() and FileAccess.file_exists(godot_path):
		_launch_button.disabled = false
	else:
		if _problem_detected_button: 
			_launch_button.disabled = true
			_problem_detected_button.enable(_version_id, true)
			set_destroy_icon()
			set_strikethrough_text()

func remove() -> void:
	if not _version_id.is_empty():
		var godot_path = VersionControl.get_godot_path(_version_id)
		
		if _is_engine_running(godot_path):
			printerr(\"ERROR: Godot Engine (%s) is running now.\" % _version_id)
			if _hint: _hint.enable()
			return 
		_launch_button.disabled = true
		_remove_button.disable()
		_texture_bar.show()
		await VersionControl.remove_engine_folder_async(_version_id, _update_deletion_progress)
		_delete_version_data(_version_id)
	super()

func _update_deletion_progress(percent: float) -> void:
	_texture_bar.update_progress(percent)

func _delete_version_data(v_id: String) -> void:
	if VersionControl._versions_data.has(v_id):
		VersionControl._versions_data.erase(v_id)
		VersionControl.save_data()

func _launch_engine_version() -> void:
	var godot_path = VersionControl.get_godot_path(_version_id)
	if godot_path.is_empty() or not FileAccess.file_exists(godot_path): 
		_check_engine_path()
		return
	
	var pid: int = OS.create_process(godot_path, [])
	if pid > 0: get_tree().quit()
	else: printerr(\"Error: Godot Engine process didn't start.\")

func _is_engine_running(exe_path: String) -> bool:
	if exe_path.is_empty() or not FileAccess.file_exists(exe_path): 
		return false
	var is_running := false
	var output := []
	var my_pid = OS.get_process_id()
	match OS.get_name():
		\"Windows\":
			var win_path = exe_path.replace(\"/\", \"\\\\\")
			var ps_cmd = \"Get-Process | Where-Object { $_.Path -eq '%s' } | Select-Object -ExpandProperty Id\" % win_path
			OS.execute(\"powershell.exe\", [\"-Command\", ps_cmd], output)
			if output.size() > 0 and not output[0].strip_edges().is_empty(): 
				is_running = true
		\"Linux\", \"macOS\", \"FreeBSD\":
			OS.execute(\"pgrep\", [\"-f\", exe_path], output)
			
			if output.size() > 0:
				var pids = output[0].split(\"\\n\", false)
				for pid_str in pids:
					var found_pid = pid_str.strip_edges().to_int()
					if found_pid > 0 and found_pid != my_pid:
						is_running = true
						break
						
	return is_running
"

[sub_resource type="GDScript" id="GDScript_vrk3i"]
script/source = "extends Button

var _edit_mode : bool = false
@export var _icon_texture : TextureRect

func _ready() -> void:
	hide()
	EventBus.edit_button_pressed.connect(_edit_mode_enable)

func _edit_mode_enable() -> void:
	_edit_mode = !_edit_mode
	visible = _edit_mode

func disable() -> void:
	_icon_texture.hide()
	disabled = true
"

