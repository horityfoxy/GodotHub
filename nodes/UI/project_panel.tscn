[sub_resource type="GDScript" id="GDScript_uyqn0"]
script/source = "extends panel_base

@export var _edit_button : Button
@export var _run_button : Button
@export var _version_label : Label

var _project_path : String = \"\"
var _godot_path : String = \"\"
var _version : String = \"\"

func _ready() -> void:
	if _edit_button: _edit_button.pressed.connect(_edit_project)
	if _run_button: _run_button.pressed.connect(_run_project)
	super()

func set_godot_path(value : String) -> void:
	_godot_path = value

func set_project_path(value : String) -> void:
	_project_path = value

func setup_icon():
	_icon_texture.setup()

func set_version(value : String) -> void:
	_version = value
	_version_label.text = \" \" + value + \" \"

func remove() -> void:
	print(\"obj has removed!\")
	var full_path : String = _project_path + \"/project.godot\"
	print(full_path)
	SaveSystem.remove_project(full_path)
	super()

func _edit_project():
	launch_project_in_editor([\"--path\", _project_path, \"-e\"])

func _run_project():
	launch_project_in_editor([\"--path\", _project_path])

func launch_project_in_editor(_args : PackedStringArray) -> void:
	if not FileAccess.file_exists(_godot_path):
		printerr(\"ERROR: Executable file not found: \", _godot_path)
		return
	
	if _project_path == \"\":
		printerr(\"ERROR: Project path is empty!\")
		return
	
	var pid: int = OS.create_process(_godot_path, _args)
	if pid > 0: 
		if _args.has(\"-e\"): get_tree().quit()
	else: printerr(\"ERROR: Failed to launch the project.\")
"

